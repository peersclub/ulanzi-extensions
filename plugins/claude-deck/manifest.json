{
  "UUID": "com.ulanzi.ulanzideck.claudedeck",
  "Name": "Claude Deck",
  "Description": "Live Claude Code session activity + two-way control on your Ulanzi D200X. Shows model, context %, and a status light (thinking / awaiting input / done), plus control keys (interrupt, approve, deny, /compact, /clear, plan mode, custom slash command) and encoder dials. Complements the Claude Code Usage and AI Cost plugins. Reads live state from a local broker written by the claude-code adapter.",
  "Author": "ulanzi-lab",
  "Version": "0.1.0",
  "Icon": "resources/plugin.png",
  "Category": "Claude Deck",
  "CategoryIcon": "resources/category.png",
  "CodePath": "dist/app.js",
  "Type": "JavaScript",
  "PrivateAPI": true,
  "SupportedInMultiActions": false,
  "OS": [{ "Platform": "mac", "MinimumVersion": "12.0" }],
  "Software": { "MinimumVersion": "3.0.11" },
  "Actions": [
    {
      "Name": "Model",
      "Tooltip": "Current Claude model + context %",
      "Icon": "resources/info.png",
      "UUID": "com.ulanzi.ulanzideck.claudedeck.model",
      "States": [{ "Image": "resources/info.png" }],
      "Controllers": ["Keypad"]
    },
    {
      "Name": "Context %",
      "Tooltip": "Context window used",
      "Icon": "resources/info.png",
      "UUID": "com.ulanzi.ulanzideck.claudedeck.context",
      "States": [{ "Image": "resources/info.png" }],
      "Controllers": ["Keypad"]
    },
    {
      "Name": "Status",
      "Tooltip": "Live session status: thinking / awaiting input / done",
      "Icon": "resources/info.png",
      "UUID": "com.ulanzi.ulanzideck.claudedeck.status",
      "States": [{ "Image": "resources/info.png" }],
      "Controllers": ["Keypad"]
    },
    {
      "Name": "Session Timer",
      "Tooltip": "Elapsed time of the current session",
      "Icon": "resources/info.png",
      "UUID": "com.ulanzi.ulanzideck.claudedeck.session",
      "States": [{ "Image": "resources/info.png" }],
      "Controllers": ["Keypad"]
    },
    {
      "Name": "Lines Changed",
      "Tooltip": "Net lines changed this session",
      "Icon": "resources/info.png",
      "UUID": "com.ulanzi.ulanzideck.claudedeck.lines",
      "States": [{ "Image": "resources/info.png" }],
      "Controllers": ["Keypad"]
    },
    {
      "Name": "Interrupt",
      "Tooltip": "Interrupt Claude (Esc)",
      "Icon": "resources/control.png",
      "PropertyInspectorPath": "property-inspector/inspector.html",
      "UUID": "com.ulanzi.ulanzideck.claudedeck.interrupt",
      "States": [{ "Image": "resources/control.png" }],
      "Controllers": ["Keypad"]
    },
    {
      "Name": "Approve",
      "Tooltip": "Approve the current permission prompt",
      "Icon": "resources/control.png",
      "PropertyInspectorPath": "property-inspector/inspector.html",
      "UUID": "com.ulanzi.ulanzideck.claudedeck.approve",
      "States": [{ "Image": "resources/control.png" }],
      "Controllers": ["Keypad"]
    },
    {
      "Name": "Deny",
      "Tooltip": "Deny the current permission prompt",
      "Icon": "resources/control.png",
      "PropertyInspectorPath": "property-inspector/inspector.html",
      "UUID": "com.ulanzi.ulanzideck.claudedeck.deny",
      "States": [{ "Image": "resources/control.png" }],
      "Controllers": ["Keypad"]
    },
    {
      "Name": "Plan Mode",
      "Tooltip": "Toggle plan mode (Shift+Tab)",
      "Icon": "resources/control.png",
      "PropertyInspectorPath": "property-inspector/inspector.html",
      "UUID": "com.ulanzi.ulanzideck.claudedeck.plan",
      "States": [{ "Image": "resources/control.png" }],
      "Controllers": ["Keypad"]
    },
    {
      "Name": "Slash Command",
      "Tooltip": "Type a configurable slash command (e.g. /compact, /clear)",
      "Icon": "resources/control.png",
      "PropertyInspectorPath": "property-inspector/inspector.html",
      "UUID": "com.ulanzi.ulanzideck.claudedeck.slash",
      "States": [{ "Image": "resources/control.png" }],
      "Controllers": ["Keypad"]
    },
    {
      "Name": "Transcript Scroll",
      "Tooltip": "Scroll the terminal/transcript with the dial",
      "Icon": "resources/dial.png",
      "UUID": "com.ulanzi.ulanzideck.claudedeck.scroll",
      "States": [{ "Image": "resources/dial.png" }],
      "Controllers": ["Encoder"]
    }
  ]
}
